{
    /* ==============================================================================
     Tên tệp tin: appsettings.json
     Tổng quan: Tệp cấu hình tham số môi trường cho ứng dụng ASP.NET Core.
     Tác giả: Nhóm 4
     Ngày sửa đổi: 10/05/2026
     ==============================================================================
  */

    "ConnectionStrings": {
        /* DefaultConnection: Chuỗi kết nối tới SQL Server.
       - Server: LAPTOP-K4MUPSS7 (Tên máy chủ CSDL của thành viên Nhóm 4).
       - Database: StudentManagementDB (Tên cơ sở dữ liệu quản lý).
       - Trusted_Connection: True (Sử dụng quyền Windows Authentication để đăng nhập).
       - TrustServerCertificate: True (Bỏ qua kiểm tra chứng chỉ SSL khi kết nối cục bộ).
    */
        "DefaultConnection": "Server=LAPTOP-K4MUPSS7;Database=StudentManagementDB;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True"
    },

    "Logging": {
        /* LogLevel: Quy định mức độ chi tiết của nhật ký hệ thống.
       - Default: Information (Ghi lại các thông tin vận hành cơ bản).
       - Microsoft.AspNetCore: Warning (Chỉ ghi lại các cảnh báo hoặc lỗi từ framework để tránh nặng file Log).
    */
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },

    /* AllowedHosts: "*" cho phép ứng dụng phản hồi mọi tên miền (Host) truy cập vào */
    "AllowedHosts": "*"
}