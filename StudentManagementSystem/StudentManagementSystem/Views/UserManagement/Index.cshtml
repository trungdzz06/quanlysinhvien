@model IEnumerable<StudentManagementSystem.Models.UserRoleViewModel>

@{
    ViewData["Title"] = "Quản Lý Phân Quyền";
}

<div class="page-container">
    <div class="breadcrumb">QUẢN TRỊ > QUẢN LÝ TÀI KHOẢN & PHÂN QUYỀN</div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">✅ @TempData["Success"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger" style="padding: 15px; background-color: #f8d7da; border: 1px solid #f5c6cb; color: #721c24; border-radius: 4px; margin-bottom: 20px;">❌ @TempData["Error"]</div>
    }

    <div class="action-bar" style="margin-bottom: 20px;">
        <p class="text-muted">Lưu ý: Chỉ thay đổi quyền khi thực sự cần thiết để đảm bảo tính toàn vẹn dữ liệu học vụ.</p>
    </div>

    <table class="data-table">
        <thead>
            <tr>
                <th>Mã Định Danh</th>
                <th>Họ Tên</th>
                <th>Email</th>
                <th>Vai Trò Hiện Tại</th>
                <th>Phân Quyền Mới</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td><strong>@user.UserId</strong></td>
                    <td>@user.FullName</td>
                    <td>@user.Email</td>
                    <td>
                        <span class="badge @(user.Role == "Student" ? "bg-info" : "bg-warning")" 
                              style="padding: 5px 10px; border-radius: 4px; color: #fff; background-color: @(user.Role == "Student" ? "#17a2b8" : "#ffc107")">
                            @user.Role
                        </span>
                    </td>
                    <td>
                        <form asp-action="UpdateRole" method="post" class="d-inline">
                            <input type="hidden" name="userId" value="@user.UserId" />
                            <select name="newRole" onchange="this.form.submit()" style="padding: 5px; border-radius: 4px; border: 1px solid #ccc;">
                                <!option value="Student" @(user.Role == "Student" ? "selected" : "")>Student</!option>
                                <!option value="Teacher" @(user.Role == "Teacher" ? "selected" : "")>Teacher</!option>
                                <!option value="Admin">Admin</!option>
                            </select>
                            @Html.AntiForgeryToken()
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<style>
    .badge { font-size: 0.85em; font-weight: bold; }
    .data-table { width: 100%; border-collapse: collapse; margin-top: 10px; }
    .data-table th, .data-table td { padding: 12px; border: 1px solid #eee; text-align: left; }
    .data-table thead { background-color: #0b3c5d; color: white; }
</style>