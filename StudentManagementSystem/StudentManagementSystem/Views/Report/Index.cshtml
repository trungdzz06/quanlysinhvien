@* 
 * ==============================================================================
 * Tên tệp tin: Index.cshtml (Lớp học phần)
 * Tổng quan: Trang quản trị danh sách các lớp học phần trong hệ thống.
 * Chức năng: Hiển thị, lọc theo học kỳ, tìm kiếm và quản lý trạng thái mở lớp.
 * Tác giả: Nhóm phát triển phần mềm
 * Ngày tạo/sửa đổi: 05/05/2026
 * ==============================================================================
 *@

@model IEnumerable<StudentManagementSystem.Models.CourseClass>
@{
    ViewData["Title"] = "Quản Lý Lớp Học Phần";
}

<div class="page-container">
    @* Phân đoạn breadcrumb: Hỗ trợ người dùng định vị vị trí trong hệ thống *@
    <div class="breadcrumb">
        ĐÀO TẠO > QUẢN LÝ LỚP HỌC PHẦN
    </div>

    @* MODULE: Thanh tác vụ nhanh - Cho phép quản trị viên khởi tạo lớp mới *@
    <div class="action-bar">
        <a asp-action="Create" class="btn btn-success">+ Mở Lớp Học Phần Mới</a>
    </div>

    @*
     * MODULE: Thanh lọc và tìm kiếm
     * Chức năng: Gửi yêu cầu lọc dữ liệu về Server thông qua phương thức GET.
     * Logic: Tự động submit form khi thay đổi giá trị học kỳ (onchange).
     *@
    <div class="filter-bar">
        <form method="get">
            <label>Chọn Học Kỳ:</label>
            <select name="semester" onchange="this.form.submit()">
                <option value="">Tất cả</option>
                @* Duyệt danh sách học kỳ từ ViewBag được Controller cung cấp *@
                @foreach (var sem in ViewBag.Semesters)
                {
                    <option value="@sem">@sem</option>
                }
            </select>

            <input type="text" name="searchTerm" placeholder="🔍 Tìm lớp, môn học..." />
            <button type="submit" class="btn btn-search">Tìm kiếm</button>
        </form>
    </div>

    @* MODULE: Bảng hiển thị dữ liệu tập trung *@
    <table class="data-table">
        <thead>
            <tr>
                <th>Mã Lớp</th>
                <th>Môn Học</th>
                <th>Giảng Viên</th>
                <th>Sĩ Số</th>
                <th>Trạng Thái</th>
                <th>Hành động</th>
            </tr>
        </thead>
        <tbody>
            @* Duyệt danh sách Model để đổ dữ liệu vào từng hàng của bảng *@
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.CourseClassId</td>
                    <td>@item.Subject?.SubjectName</td>
                    <td>@item.Teacher?.FullName</td>
                    @* Hiển thị tỷ lệ lấp đầy của lớp học phần *@
                    <td>@item.CurrentStudents/@item.MaxStudents</td>
                    
                    @*
                     * LOGIC PHỨC TẠP: PHÂN LOẠI TRẠNG THÁI (STATUS BADGE)
                     * Sử dụng cấu trúc rẽ nhánh để hiển thị màu sắc và biểu tượng 
                     * tương ứng với từng trạng thái thực tế của lớp học phần.
                     *@
                    <td>
                        @if (item.Status == "Mở đăng ký")
                        {
                            <span class="status-active">🟢 @item.Status</span>
                        }
                        else if (item.Status == "Đã đầy")
                        {
                            <span class="status-full">🔴 @item.Status</span>
                        }
                        else
                        {
                            <span class="status-pending">🟡 @item.Status</span>
                        }
                    </td>
                    
                    @* Nhóm các nút tương tác trực tiếp trên từng bản ghi *@
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.CourseClassId" class="btn btn-edit">✏️</a>
                        <button class="btn btn-info">⚙️</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>