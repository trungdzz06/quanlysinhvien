@model StudentManagementSystem.Models.ReportViewModel
@{
    ViewData["Title"] = "Báo Cáo & Thống Kê";
}

<div class="page-container">
    <div class="breadcrumb">
        BÁO CÁO & THỐNG KÊ > KẾT QUẢ HỌC TẬP
    </div>

    <div class="filter-bar">
        <form method="get">
            <label>Khoa:</label>
            <select name="facultyId">
                <option value="">Tất cả</option>
                @foreach (var faculty in ViewBag.Faculties)
                {
                    <!option value="@faculty.FacultyId" @(Model.FacultyId == faculty.FacultyId ? "selected" : "")>@faculty.FacultyName</!option>
                }
            </select>

            <label>Lớp:</label>
            <select name="classId">
                <option value="">Tất cả</option>
                @foreach (var cls in ViewBag.Classes)
                {
                    <!option value="@cls.ClassId" @(Model.ClassId == cls.ClassId ? "selected" : "")>@cls.ClassName</!option>
                }
            </select>

            <label>Học kỳ:</label>
            <select name="semester">
                <option value="">Tất cả</option>
                @if (ViewBag.Semesters != null)
                {
                    foreach (var sem in ViewBag.Semesters)
                    {
                        <!option value="@sem" @(Model.Semester == sem ? "selected" : "")>@sem</!option>
                    }
                }
            </select>

            <button type="submit" class="btn btn-search">Xem Báo Cáo</button>
        </form>

        <div class="export-buttons">
            <a asp-action="ExportPDF" asp-route-facultyId="@Model.FacultyId" asp-route-classId="@Model.ClassId" asp-route-semester="@Model.Semester" class="btn btn-danger">📄 Xuất PDF</a>
            <a asp-action="ExportExcel" asp-route-facultyId="@Model.FacultyId" asp-route-classId="@Model.ClassId" asp-route-semester="@Model.Semester" class="btn btn-primary">📊 Xuất Excel</a>
        </div>
    </div>

    <div class="stats-overview">
        <h3>TỔNG QUAN XẾP LOẠI HỌC LỰC</h3>
        <div class="classification-stats">
            <div class="stat-item">Xuất sắc: @Model.ExcellentCount (@(Model.StudentReports.Count > 0 ? (Model.ExcellentCount * 100 / Model.StudentReports.Count) : 0)%)</div>
            <div class="stat-item">Giỏi: @Model.GoodCount (@(Model.StudentReports.Count > 0 ? (Model.GoodCount * 100 / Model.StudentReports.Count) : 0)%)</div>
            <div class="stat-item">Khá: @Model.FairCount (@(Model.StudentReports.Count > 0 ? (Model.FairCount * 100 / Model.StudentReports.Count) : 0)%)</div>
            <div class="stat-item">Trung bình: @Model.AverageCount (@(Model.StudentReports.Count > 0 ? (Model.AverageCount * 100 / Model.StudentReports.Count) : 0)%)</div>
            <div class="stat-item">Yếu: @Model.PoorCount (@(Model.StudentReports.Count > 0 ? (Model.PoorCount * 100 / Model.StudentReports.Count) : 0)%)</div>
        </div>
    </div>

    <table class="data-table">
        <thead>
            <tr>
                <th>MSSV</th>
                <th>Họ Tên</th>
                <th>Điểm TBC (Hệ 10)</th>
                <th>Tích lũy (Hệ 4)</th>
                <th>Xếp loại</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var report in Model.StudentReports)
            {
                <tr>
                    <td>@report.MSSV</td>
                    <td>@report.FullName</td>
                    <td>@report.GPA10.ToString("F1")</td>
                    <td>@report.GPA4.ToString("F1")</td>
                    <td>@report.Classification</td>
                </tr>
            }
        </tbody>
    </table>
</div>