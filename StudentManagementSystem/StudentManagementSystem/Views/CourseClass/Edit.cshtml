@* * ==============================================================================
 * Tên tệp tin: Edit.cshtml (CourseClass)
 * Tổng quan: Giao diện biểu mẫu cập nhật thông tin Lớp học phần đã tồn tại.
 * Chức năng: Cho phép thay đổi môn học, giảng viên, lịch trình và quản lý sĩ số.
 * Tác giả: Nhóm 4
 * Ngày tạo/sửa đổi: 10/05/2026
 * ==============================================================================
 *@

@model StudentManagementSystem.Models.CourseClass

@{
    ViewData["Title"] = "Chỉnh Sửa Lớp Học Phần";
}

<div class="page-container">
    @* Thanh điều hướng hỗ trợ người dùng theo dõi vị trí thao tác *@
    <div class="breadcrumb">ĐÀO TẠO > QUẢN LÝ LỚP HP > CẬP NHẬT</div>

    <div class="form-card" style="max-width: 800px; margin: 20px auto; background: #fff; padding: 30px; border-radius: 10px; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">
        
        @* Form gửi dữ liệu POST đến Action Edit trong Controller *@
        <form asp-action="Edit" method="post">
            
            @* * LOGIC PHỨC TẠP: BẢO VỆ KHÓA CHÍNH
             * asp-for="CourseClassId" (type="hidden"): Giữ mã ID của lớp học phần trong luồng POST.
             * Đây là thông tin quan trọng để Entity Framework thực hiện câu lệnh Update đúng bản ghi trong SQL.
             *@
            <input type="hidden" asp-for="CourseClassId" />

            @* * GIAO DIỆN DẠNG LƯỚI (GRID LAYOUT):
             * Giúp sắp xếp các cặp thông tin liên quan đối xứng nhau, dễ quan sát.
             *@
            <div class="grid-form" style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                
                @* Hiển thị mã lớp ở chế độ chỉ đọc để đảm bảo tính nhất quán của dữ liệu *@
                <div class="form-group">
                    <label>Mã Lớp HP (Cố định):</label>
                    <input class="form-control" value="@Model.CourseClassId" disabled />
                    <small class="text-muted">Định danh duy nhất không thể chỉnh sửa.</small>
                </div>

                @* Cập nhật Môn học: Load danh sách từ ViewBag.Subjects *@
                <div class="form-group">
                    <label>Môn Học:</label>
                    <select asp-for="SubjectCode" class="form-control"
                            asp-items="@(new SelectList(ViewBag.Subjects, "SubjectCode", "SubjectName"))">
                    </select>
                </div>

                @* Cập nhật Giảng viên: Load danh sách từ ViewBag.Teachers *@
                <div class="form-group">
                    <label>Giảng Viên:</label>
                    <select asp-for="TeacherId" class="form-control"
                            asp-items="@(new SelectList(ViewBag.Teachers, "TeacherId", "FullName"))">
                    </select>
                    <span asp-validation-for="TeacherId" class="text-danger" style="color: red; font-size: 0.9em; display: block; margin-top: 5px;"></span>
                </div>

                @* Cập nhật thông tin Học kỳ *@
                <div class="form-group">
                    <label>Học Kỳ:</label>
                    <input asp-for="Semester" class="form-control" />
                </div>

                @* * MODULE: QUẢN LÝ QUY MÔ LỚP HỌC
                 * MaxStudents: Giới hạn tối đa sinh viên.
                 * CurrentStudents: Số lượng sinh viên thực tế đã đăng ký thành công.
                 *@
                <div class="form-group">
                    <label>Sĩ số tối đa:</label>
                    <input asp-for="MaxStudents" class="form-control" />
                </div>

                <div class="form-group">
                    <label>Sĩ số hiện tại:</label>
                    <input asp-for="CurrentStudents" class="form-control" />
                </div>

                @* Cập nhật thời khóa biểu *@
                <div class="form-group">
                    <label>Lịch học:</label>
                    <input asp-for="Schedule" class="form-control" />
                </div>

                @* Quản lý trạng thái vận hành của lớp học phần *@
                <div class="form-group">
                    <label>Trạng thái:</label>
                    <select asp-for="Status" class="form-control">
                        <option value="Mở đăng ký">Mở đăng ký</option>
                        <option value="Chờ duyệt">Chờ duyệt</option>
                        <option value="Đã đầy">Đã đầy</option>
                    </select>
                </div>
            </div>

            @* Thanh lệnh điều hướng và xác nhận lưu *@
            <div class="action-bar-bottom" style="margin-top: 30px; text-align: right; border-top: 1px solid #eee; padding-top: 20px;">
                @* Quay lại trang danh sách quản lý *@
                <a asp-action="Index" class="btn btn-cancel">Quay lại</a>
                
                @* Gửi yêu cầu cập nhật các thay đổi vào CSDL *@
                <button type="submit" class="btn btn-primary">💾 Lưu thay đổi</button>
            </div>
        </form>
    </div>
</div>