@model StudentManagementSystem.Models.CourseClass

@{
    ViewData["Title"] = "Chi Tiết Lớp Học Phần";
}

<div class="page-container">
    <div class="breadcrumb">
        ĐÀO TẠO > QUẢN LÝ LỚP HỌC PHẦN > @Model.CourseClassId
    </div>

    @* Hiển thị thông báo phản hồi từ hệ thống (TempData) *@
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            ✅ @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">
            ❌ @TempData["Error"]
        </div>
    }

    <div class="action-bar" style="justify-content: space-between; align-items: center; margin-bottom: 20px;">
        <h3 style="margin: 0; color: #0b3c5d;">DANH SÁCH SINH VIÊN ĐĂNG KÝ</h3>
        <div style="display: flex; gap: 10px;">
            <a asp-action="ExportClassStudents" asp-route-id="@Model.CourseClassId" class="btn btn-primary" title="Xuất danh sách sinh viên ra CSV">📥 Xuất DS (.csv)</a>
            <a asp-action="Index" class="btn btn-cancel" style="text-decoration:none;">⬅️ Quay lại</a>
        </div>
    </div>

    <div style="background: #fdfdfd; padding: 20px; border: 1px solid #ddd; border-radius: 8px; margin-bottom: 20px;">
        <p><strong>Mã Lớp:</strong> @Model.CourseClassId</p>
        <p><strong>Môn Học:</strong> @Model.Subject?.SubjectName (@Model.SubjectCode)</p>
        <p><strong>Giảng Viên:</strong> @Model.Teacher?.FullName</p>
        <p><strong>Lịch Học:</strong> @Model.Schedule</p>
        <p><strong>Học Kỳ:</strong> @Model.Semester</p>
        <p><strong>Sĩ Số:</strong> @Model.CurrentStudents / @Model.MaxStudents</p>
    </div>

    <table class="data-table">
        <thead>
            <tr>
                <th>STT</th>
                <th>Mã Sinh Viên</th>
                <th>Họ Tên</th>
                <th>Ngày Sinh</th>
                <th>Trạng Thái Đăng Ký</th>
                <th>Hành động</th>
            </tr>
        </thead>
        <tbody>
            @if (ViewBag.Registrations != null)
            {
                var index = 1;
                foreach (var reg in ViewBag.Registrations)
                {
                    <tr>
                        <td>@index</td>
                        <td><strong>@reg.Student?.MSSV</strong></td>
                        <td>@reg.Student?.FullName</td>
                        <td>@(reg.Student?.DateOfBirth.ToString("dd/MM/yyyy"))</td>
                        <td>
                            @if(reg.Status == "Đã chốt")
                            {
                                <span style="color: #d9534f; font-weight: bold;">🔴 @reg.Status</span>
                            }
                            else
                            {
                                <span style="color: #5cb85c; font-weight: bold;">🟢 @reg.Status</span>
                            }
                        </td>
                        <td>
                            <form asp-action="RemoveStudent" method="post" style="display:inline;" onsubmit="return confirm('Bạn có chắc chắn muốn xóa sinh viên @reg.Student?.FullName khỏi lớp học phần này?')">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="registrationId" value="@reg.RegistrationId" />
                                <button type="submit" class="btn btn-delete" style="padding: 4px 8px; font-size: 0.85em;">Xóa</button>
                            </form>
                        </td>
                    </tr>
                    index++;
                }
                
                if (index == 1)
                {
                    <tr>
                        <td colspan="6" style="text-align:center; padding: 30px; color: #888;">
                            Lớp học phần này chưa có sinh viên nào đăng ký.
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
